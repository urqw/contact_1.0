:kontakt
cls
invkill
perkill
Style_BackColor="#000000"
style_dos_textcolor=15

health=100
bronik=0

myweapon=0
weapon1=0
weapon2=0
weapon3=0
weapon4=0
weapon5=0
patron3=0
patron4=0
patron5=0
magazin3-0
magazin4=0
magazin5=0


aptechka=0
spray=0
bloknot=10
goto start
end

;===========================================================================================================================================================

:start
cls
pln Контакт 1.0. Вторжение.
pln #/$
pln #/$
pln #/$
style_dos_textcolor=10
pln #/$
pln          []  []  [][]  []  [] [][][]  [][] []  [] [][][]
pln          []  [] []  [] []  []   []   [] [] []  []   []
pln          [] []  []  [] []  []   []  []  [] [] []    []
pln          [][]   []  [] [][][]   []  [][][] [][]     []
pln          [] []  []  [] []  []   []  []  [] [] []    []
pln          []  [] []  [] []  []   []  []  [] []  []   []
pln          []  []  [][]  []  []   []  []  [] []  []   []

style_dos_textcolor=15
btn game,Новая игра.
btn about,Описание.
btn help,Помощь.
btn avtor,Автор.
btn blag,Благодарность.
end

:about
cls
pln   Не далекое будущее. Или близкое прошлое... Но однажды произошел контакт. Корабли пришельцев прилетели на Землю. Явно, что намерения их были совсем не дружелюбными...
pln   Нам придется играть в роли простого солдата секретной части. Несколько классов монстров. Оружие на любой вкус. Загадки и многое другое.
btn start,В главное меню
end

:help
cls
pln Не забывайте пользоваться инвентарем (Вызвать инвентарь можно нажав клавишу F6). Что бы вооружиться, перезарядить оружие, осмотреть предмет или карту. Сохраняйтесь при помощи блокнота.
btn start,В главное меню
end

:blag
cls
pln Огромное спасибо qwerty, за потрясающий бета-тест, энтузиазм, поддержку и дельные советы.
btn start,В главное меню
end



:avtor
cls
pln Автор: Chicago1920
pln Для связи: e-mail: Chicago1920@mail.ru
pln                        ICQ: 254881271
btn start,В главное меню
end



;===========================================================================================================================================================

:game
cls
pln   Когда я начинал служить в армии, я даже не мог представить что такое произойдет. Думаю, что ни один солдат мира, ни в одной армии не думал, что такое возможно. Но это оказалось реальностью...
btn game2,Далее.
end

:game2
cls
pln   Я нес службу в небольшой секретной армейской части. Оператором пункта наблюдения, "дежурный по красной кнопке" , как называли эту должность. Где-то в лесу находились шесть шахт межконтинентальных ракет с ядерными боеголовками.
btn game3,Далее.
end

:game3
cls
inv+ Здоровье
pln   Неожиданно с поверхности стали доноситься какие-то взрывы. Звуки стрельбы. Включилась тревога. При этом бункер надежно изолировался. Никто не мог сюда проникнуть из вне. И даже воздух начинал подаваться из специальной установки.
btn bunker,Осмотреться.
end

;===========================================================================================================================================================

:bunker
a1=1
cls
instr Loc=bunker
pln   Секретный военный бункер, где находится легендарная "красная  кнопка", а так же куча другого оборудования. Именно здесь ты находился на своих дежурствах.
if sirena=0 then pln   В случае тревоги бункер надежно изолировался и включалась система автономного жизнеобеспечения для персонала.
btn bunker2,Посмотреть запись камеры наблюдения.
if sirena=0 then btn bunker3,Отключить тревогу.
if map=0 then btn maps,Взять карту.
if blok=0 then btn bloks,Взять блокнот.
if sirena=1 then btn D4,Выйти на улицу.
end

:maps
pln Ты берешь карту. Это план расположения всех объектов в части.
inv+ Карта
map=1
btn bunker,Назад.
end

:bloks
pln Ты берешь блокнот. 
inv+ Блокнот
blok=1
btn bunker,Назад.
end


:bunker2
cls
pln   Прямая трансляция с камеры наружного видеонаблюдения. Видны пожары, какие то взрывы. Раненные и умирающие люди и...
pln Ты готов поклясться что заметил неопознанные летающий объект в форме блюдца!
btn bunker,Отойти.
end

:bunker3
cls
pln   Ты отключаешь сигнализацию тревоги. Теперь из бункера можно будет выбраться. Нужно бы связаться с командованием в штабе, что бы понять что случилось.
sirena=1
btn bunker,Отойти.
end

:prohod
a2=1
cls
instr Loc=prohod
pln   Проходная. В связи с тревогой ворота были автоматически закрыты. Теперь здесь не пройти. Но небольшая часть ворота отогнута в сторону. Человеку конечно не пролезть, но собака вполне могла бы здесь протиснуться.
if prohdrob=0 then btn prohdrob1,Взять дробовик.
btn A2,Выйти на улицу.
end

:prohdrob1
pln Ты находишь дробовик.
weapon5=1
patron5=2
magazin5=10
prohdrob=1
inv+ Дробовик(16мм)
inv+ 10,Патроны_16мм
btn prohod,Назад.
end

:kotel
a3=1
cls
instr Loc=kotel
if par=0 then pln   Это котельная. Труба перебита и все котельная в густом обжигающем паре. & health=health-10
if par=1 then pln   Это котельная. Труба перебита, но так как ты перекрыл вентиль, то тебя больше не обжигает паром.
if par=1 then kotpist=1
if kotpist=1 then btn kotpist1,Взять пистолет. 
btn D1,Выйти на улицу.
btn kotel2,Идти дальше.
end

:kotpist1
pln Ты находишь пистолет.
weapon4=1
patron4=6
magazin4=magazin4+30
kotpist=1
inv+ Пистолет(11.2мм)
inv+ 30,Патроны_11.2мм
btn kotel,Назад.
end

:kotel2
cls
pln   Вспомогательное помещение котельное. Здесь находится несколько одинаковых вентилей.
btn ventel21,Повернуть вентиль.
if par=0 then btn ventel22,Повернуть вентиль.
if par=1 then btn ventel23,Повернуть вентиль.
btn kotel,Идти в котельную.
end

:ventel21
pln   Ты повернул вентель.
btn kotel2,Отойти.
end

:ventel22
pln   Ты повернул вентель.
par=1
btn kotel2,Отойти.
end

:ventel23
pln   Ты повернул вентель.
par=0
btn kotel2,Отойти.
end

:gospital
a4=1
cls
instr Loc=gospital
pln   Это небольшой госпиталь. Сюда помещали больных и раненных, хотя обычно он пустовал.
if gospapt=0 then btn gosapt1,Взять аптечку.
btn gospital2,Пройти в операционную.
btn A6,Выйти на улицу.
end

:gosapt1
pln Ты находишь аптечку.
inv+ Аптечка
aptechka=aptechka+1
gospapt=1
btn gospital,Назад.
end

:gospital2
cls
pln   Это операционная. На столе лежит распотрашенный человек. Кишки его вывалились наружу. Незавидная участь...
if gospnoz=0 then btn gospnoz1,Взять нож.
btn gospital,Выйти из операционной.
end

:gospnoz1
pln Ты вытаскиваешь нож из трупа.
inv+ Нож
weapon1=1
gospnoz=1
btn gospital2,Назад.
end

:stol
a5=1
cls
instr Loc=stol
pln   Столовая. Опрокинутые столы и стулья. Под ногами хрустит разбитая посуда.
if stolapt=0 then btn stolapt1,Взять аптечку.
btn C6,Выйти на улицу.
end

:stolapt1
pln Ты находишь аптечку.
inv+ Аптечка
aptechka=aptechka+1
stolapt=1
btn stol,Назад.
end

:san
a6=1
cls
instr Loc=san
pln   Это сан узел. Слева находится дверь ведущая в душевые. а справа в туалеты.
btn san1,В душевые.
btn san2,В туалет.
btn C1,Выйти на улицу.
end

:san1
cls
pln   Душевые. С потолка свисают патрубки, из которых не спеша капает вода. Так же, здесь находятся несколько лавочек.
btn san,Выйти из душевой.
end

:san2
cls
pln   Несмотря на то что это туалет, все здесь так и сверкает чистотой. Заслуга проштрафившихся солдатов.
if sanpist=0 then btn sanpat1,Взять патроны.
btn san,Выйти из туалета.
end

:sanpat1
Ты находишь патроны к пистолету.
magazin4=magazin4+30
sanpist=1
inv+ 30,Патроны_11.2мм
btn san2,Назад.
end

:garazh
a7=1
cls
instr Loc=garazh
pln   Это гараж. Здесь находятся несколько джипов и БМП.
if garkan=0 then btn garcist1,Взять канистру.
btn A4,Выйти на улицу.
end

:garcist1
pln Ты находишь пустую канистру.
inv+ Канистра
garkan=1
btn garazh,Назад.
end

:cist
a8=1
cls
instr Loc=cist
pln   Перед тобой находятся несколько больших цистерн. Запас горючего для вертолета и техники в гараже.
if cistgor=0 and garkan=1 then btn cistgor1,Заполнить канистру.
btn H6,Отойти от цистерн.
end

:cistgor1
pln Ты переливаешь немного горючего из цистерны в канистру.
inv- Канистра
inv+ Канистра_с_горючим
cistgor=1
btn cist,Назад.
end

:shtab
a9=1
cls
instr Loc=shtab
pln   Здесь находится штаб командования. На столе разбросаны бумаги, опрокинуты стулья. Видно, что люди в спешке покидали это место.
if radio=0 then btn shtab2,Включить рацию.
if shtabrev=0 then btn shtabrev1,Взять револьвер.
btn B5,Выйти на улицу.
end

:shtabrev1
pln В ящике стола ты находишь револьвер.
weapon3=1
patron3=6
magazin3=magazin3+35
shtabrev=1
inv+ Револьвер(9мм)
inv+ 35,Патроны_9мм
btn shtab,Назад.
end

:shtab2
cls
pln   Ты включаешь рацию и тут же слышишь истошные вопли, сквозь которые кто-то пытается сделать доклад:
pln "... нападение на Сумеречный город не отбито! Последний бой силами полиции с пришельцами состоялся на вокзале... У нас большие потери! Они применяют какие-то лучи... Люди начинают мутировать... Пришельцы намного превосходят нас в ..."
pln Запись прервал какой то животный рык.
pln   Пришельцы напали на Суммеречный город? Пришельцы??? И люди проигрывают битву?! Но в городе живет моя жена и  дочь. Что же случится с ними? Мне нужно попасть в Суммеречный город!
radio=1
btn shtab,Выключить рацию.
end

:shtab3
cls
pln Порывшись в ящиках стола ты нашел револьвер.
btn shtab,Отойти от стола.
end

:sklad
a10=1
cls
instr Loc=sklad
pln   Большой армейский склад. Здесь можно найти все, от гранотомета, до ложки. Вот только нужно знать, где искать. Иначе можно потратить очень много времени.
if skladpat=0 then btn skladpat1,Взять аммуницию.
btn F5,Выйти на улицу.
end

:skladpat1
pln Ты нахаодишь патроны и бронежилет.
inv+ Патроны_9мм
inv+ Патроны_16мм
inv+ Бронежилет
bronik=100
patron3=patron3+35
patron5=patron5+100
skladpat=1
btn sklad,Назад
end

:kazarma
a11=1
cls
instr Loc=kazarma
pln   Здесь находятся несколько блоков казарм. Одно из них объято огнем, второе полностью разрушено. Не повезло тем, кто там находился.
btn F3,Ототи от казарм.
end

:sport
a12=1
cls
instr Loc=sport
pln   Спортплощака. Небольшое поле, брусья и турники.
if sportbit=0 then btn sportbit1,Взять биту и спрей.
btn B3,Уйти со спортплощадки.
end

:sportbit1
pln Ты находишь бейсбольную биту и два спрея.
inv+ Бита
inv+ 2,Спрей
weapon2=1
sportbit=1
spray=spray+2
btn sport,Назад.
end

:ploshadka
cls
instr Loc=ploshadka
pln   Вертолетная площадка. Одиноко стоит с виду не поврежденный, боевой вертолет. Или "вертушка" как мы его называли.
;if a1=1 and a2=1 and a3=1 and a4=1 and a5=1 and a6=1 and a7=1 and a8=1 and a9=1 and a10=1 and a11=1 and a12=1 then btn vert,Сесть в вертолет.
btn vert,Сесть в вертолет.
if cistgor=1 then btn gas,Заправить вертолет.
btn H1,Уйти с вертолетной площадки.
end

:gas
pln Ты заправляешь вертолет горючим.
zapravil=1
inv- Канистра_с_горючим
btn ploshadka,Назад.
end

:vert
cls
instr Loc=vert
pln Ты сидишь за штурвалом вертолета. Высший пилотаж ты конечно же не покажешь, но долететь из пункта А в пункт Б сможешь.
if zapravil=0 then pln Датчик горючего на нуле.
if zapravil=1 then pln Вертолет заправлен и готов к полету.
if zapravil=0 then btn ploshadka,Выйти из вертолета.
if zapravil=1 then btn poehali,Взлететь.
end

:poehali
cls
pln   Ты аккуратно поднимаешь вертолет в воздух и направляешь в сторону Суммеречного города. У тебя там остались жена и дочь, которые возможно погибли. С содроганием подумав об этом, ты увеличиваешь скорость.
btn  poehali2,Далее.
end

:poehali2
cls
pln   До города оставалось лететь минут пятнадцать, когда раздался противный сигнал аварийной тревоги и лампочки замигали красным светом. Вертолет по спирали круто пошел вниз...
pln   Ты упорно дергал рычаги пытаясь вывести машину из крена. Причем ты даже не понимал, что сделал не так и из-за чего вертолет стал падать.
btn  poehali3,Далее.
end

:poehali3
cls
pln   Земля стремительно приближалась, когда ты обо что-то ударился головой и картинка перед глазами приобрела богровые оттенки. Далеше была только пустота...
btn finish,Конец.
end

;===========================================================================================================================================================

:A1
cls
style_dos_textcolor=15
pln Квадрат А1.
pln Вокруг находятся постройки твоей части.
instr Loc=A1
чикарандом= rnd15
if чикарандом=7 then goto Ворон
if чикарандом=8 then goto Змея
if чикарандом=9 then goto Собака
if чикарандом=10 then goto Зомби1
if чикарандом=11 then goto Зомби2
btn A2,Юг.
btn B1,Восток.
end

