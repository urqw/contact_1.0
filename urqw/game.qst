;===========================================================================================================================================================

:Ворон
instr enemyname=Ворон
enemy=1
enemyhealth=10
goto boy
end

:Змея
instr enemyname=Змея
enemy=2
enemyhealth=20
goto boy
end

:Собака
instr enemyname=Собака
enemy=3
enemyhealth=30
goto boy
end

:Зомби1
instr enemyname=Зомби
enemy=4
enemyhealth=40
goto boy
end

:Зомби2
instr enemyname=Зомби
enemy=5
enemyhealth=50
goto boy
end

;===========================================================================================================================================================

:boy
cls
if enemy=0 then goto #%Loс$
proc status
pln #enemyname$ нападает на тебя! Что делать?
;if myweapon<3 then btn fight,Ударить.
;if myweapon>2 then btn fight,Стрелять.
btn fight,Атаковать.
btn pobeg,Бежать.
end

:fight
;урон от игрока
чикарандом= rnd10
if myweapon=0 then damage=0+чикарандом
if myweapon=1 then damage=5+чикарандом
if myweapon=2 then damage=10+чикарандом
if myweapon=3 then damage=20+чикарандом
if myweapon=4 then damage=40+чикарандом
if myweapon=5 then damage=60+чикарандом
if myweapon=0 then pln #enemyname$ прямо перед тобой. Ты бьешь кулаками и ранишь врага на #damage$. & enemyhealth=enemyhealth-damage
if myweapon=1 then pln #enemyname$ прямо перед тобой. Ты бьешь ножом и ранишь врага на #damage$. & enemyhealth=enemyhealth-damage
if myweapon=2 then pln #enemyname$ прямо перед тобой. Ты бьешь дубинкой и ранишь врага на #damage$. & enemyhealth=enemyhealth-damage
if myweapon=3 and patron3>0 then pln #enemyname$ прямо перед тобой. Ты стреляешь из револьвера и ранишь врага на #damage$. & enemyhealth=enemyhealth-damage & patron3=patron3-1
if myweapon=4 and patron4>0 then pln #enemyname$ прямо перед тобой. Ты стреляешь из пистолета и ранишь врага на #damage$. & enemyhealth=enemyhealth-damage & patron4=patron4-1
if myweapon=5 and patron5>0 then pln #enemyname$ прямо перед тобой. Ты стреляешь из дробовика и ранишь врага на #damage$. & enemyhealth=enemyhealth-damage & patron5=patron5-1
if myweapon=3 and patron3<1 then pln У тебя закончились патроны в револьвере. 
if myweapon=4 and patron4<1 then pln У тебя закончились патроны в пистолете.
if myweapon=5 and patron5<1 then pln У тебя закончились патроны в дробовике.

if enemyhealth<1 then pln Враг мертв. Ты его убил. & enemy=0 & pause 2000 & goto #%Loc$

;урон от врага
чикарандом= rnd10
if enemy=1 then enemydamage=0+чикарандом
if enemy=2 then enemydamage=5+чикарандом
if enemy=3 then enemydamage=10+чикарандом
if enemy=4 then enemydamage=15+чикарандом
if enemy=5 then enemydamage=20+чикарандом
if enemy=6 then enemydamage=25+чикарандом

if bronik>0 then bronik=bronik-#enemydamage$
if bronik<1 then health=health-#enemydamage$

if enemy>0 then pln #enemyname$ атакует тебя и ранит на #enemydamage$.

if health<1 then pln #enemyname$ убивает тебя. & pause 2000 & goto die
pause 2000
goto boy
end

:status
style_dos_textcolor=10 ;красный
p #health$ +   
style_dos_textcolor=6 ;хаки
p #bronik$ U   
style_dos_textcolor=15 ;белый
if myweapon=0 then pln Кулаки
if myweapon=1 then pln Нож
if myweapon=2 then pln Бита
if myweapon=3 then pln Револьвер (#patron3$/#magazin3$)
if myweapon=4 then pln Пистолет (#patron4$/#magazin4$)
if myweapon=5 then pln Дробовик (#patron5$/#magazin5$)
style_dos_textcolor=12 ;синий
pln #enemyhealth$ + 
style_dos_textcolor=15
end

:pobeg
